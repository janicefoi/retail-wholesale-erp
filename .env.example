# ============================================================
# DATABASE (Supabase / PostgreSQL)
# ============================================================
# Get this from: Supabase Dashboard → Settings → Database → Connection string → URI
# Local Docker dev (port 5434 — see docker-compose.yml):
# DATABASE_URL="postgresql://postgres:postgres@localhost:5434/jsh_erp"
# DIRECT_URL="postgresql://postgres:postgres@localhost:5434/jsh_erp"
# Production (Supabase):
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres?pgbouncer=true"
# Direct connection for Prisma migrations (bypasses PgBouncer)
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# ============================================================
# NEXTAUTH
# ============================================================
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-key-here"
# The canonical URL of your app
NEXTAUTH_URL="http://localhost:3000"

# ============================================================
# SUPABASE (for Storage / future use)
# ============================================================
NEXT_PUBLIC_SUPABASE_URL="https://[YOUR-PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# ============================================================
# APP
# ============================================================
NEXT_PUBLIC_APP_NAME="JSH Motorcycle Spare Parts"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Currency for Kenya: KES
NEXT_PUBLIC_CURRENCY="KES"
NEXT_PUBLIC_CURRENCY_SYMBOL="KSh"
